#!/bin/sh /etc/rc.common
# procd service for Xray-core (GL.iNet Mudi 7 / OpenWrt 23.05)
# Installed to /etc/init.d/xray by scripts/install.sh.

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/xray
CONF=/etc/xray/config.json

start_service() {
    [ -x "$PROG" ] || return 1
    [ -f "$CONF" ] || return 1
    procd_open_instance
    procd_set_param command "$PROG" run -c "$CONF"
    procd_set_param env XRAY_LOCATION_ASSET=/usr/share/xray
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param file "$CONF"
    procd_close_instance
}

stop_service() {
    :
}
