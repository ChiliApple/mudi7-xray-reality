#!/bin/sh /etc/rc.common
# procd service for hev-socks5-tunnel (lwIP tun2socks -> Xray SOCKS 10808)
START=99
STOP=10
USE_PROCD=1
PROG=/usr/bin/hev-socks5-tunnel
CONF=/etc/hev/config.yaml
start_service() {
    [ -x "$PROG" ] || return 1
    procd_open_instance
    procd_set_param command "$PROG" "$CONF"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
