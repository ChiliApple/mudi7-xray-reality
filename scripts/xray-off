#!/bin/sh
# xray-off — tunnel OFF: remove routing, stop hev+Xray. Fail-safe.
TUN=tun0
TABLE=200
LAN_IF=br-lan

LAN_NET="$(ip -4 route show dev "$LAN_IF" proto kernel scope link 2>/dev/null | awk '{print $1}' | head -1)"
[ -n "$LAN_NET" ] && ip rule del from "$LAN_NET" lookup "$TABLE" pref 200 2>/dev/null
[ -n "$LAN_NET" ] && ip rule del to "$LAN_NET" lookup main pref 100 2>/dev/null
ip route flush table "$TABLE" 2>/dev/null

# leftovers from earlier attempts
nft delete table inet xray 2>/dev/null
ip rule del fwmark 0x1 lookup 100 2>/dev/null
ip route flush table 100 2>/dev/null

/etc/init.d/hev stop 2>/dev/null; /etc/init.d/hev disable 2>/dev/null
/etc/init.d/xray stop 2>/dev/null; /etc/init.d/xray disable 2>/dev/null

# hev cleans up tun0 itself; just in case
ip link show "$TUN" >/dev/null 2>&1 && { ip link set "$TUN" down 2>/dev/null; ip tuntap del mode tun dev "$TUN" 2>/dev/null; }
# --- DNS: nudge AdGuard so DoH goes DIRECT again (captive-portal capable) ---
for c in $(ls /etc/init.d/ 2>/dev/null | grep -i guard); do /etc/init.d/"$c" restart >/dev/null 2>&1; break; done
echo "xray-off: tunnel OFF, traffic direct (fail-safe)."
