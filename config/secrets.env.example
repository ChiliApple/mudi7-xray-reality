# secrets.env — LOCAL file, NEVER commit to git!
# (listed in .gitignore). Copy to /etc/xray/secrets.env and fill in.
#
# Values come from your Xray SERVER config (realitySettings) or from a
# working VLESS-REALITY client link.
#
# Security: chmod 600 /etc/xray/secrets.env

XRAY_SERVER="your.server.ip.or.domain"
XRAY_PORT="8443"
XRAY_UUID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
XRAY_PBK="your_reality_public_key"
XRAY_SID="your_short_id"
XRAY_SNI="www.apple.com"
XRAY_FP="chrome"
