# secrets.env — LOKALE Datei, NIEMALS ins Git committen!
# (steht in .gitignore). Kopieren nach /etc/xray/secrets.env und ausfuellen.
#
# Werte stammen aus deiner Xray-SERVER-Config (realitySettings) bzw. dem
# funktionierenden VLESS-REALITY-Client-Link.
#
# Sicherheit: chmod 600 /etc/xray/secrets.env

XRAY_SERVER="deine.server.ip.oder.domain"
XRAY_PORT="8443"
XRAY_UUID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
XRAY_PBK="dein_reality_public_key"
XRAY_SID="deine_short_id"
XRAY_SNI="www.apple.com"
XRAY_FP="chrome"
