XRAY_VERSION=v26.6.1

# Xray-core pinned.
# Reason for this version: the client reports its version in the REALITY
# handshake (here 26.6.1). From xray-core 26.7.11 on, REALITY SERVERS default
# to minClientVer=26.3.27 and reject older clients. 26.6.1 >= 26.3.27
# -> clears the bar natively, without having to weaken the server.
#
# To bump: change XRAY_VERSION here AND in scripts/install.sh, then run
# install.sh again (verifies SHA256 automatically).
